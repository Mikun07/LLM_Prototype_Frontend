{
  "name": "reqsmell-frontend",
  "private": true,
  "version": "2.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "version:current": "git describe --tags --always --dirty",
    "version:list": "git tag --list",
    "version:use": "powershell -ExecutionPolicy Bypass -File ./scripts/use-version.ps1",
    "version:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-version.ps1",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-hooks.ps1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "axios": "^1.7.7",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.454.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.8.1",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "9.27.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "typescript-eslint": "8.50.0",
    "vite": "6.4.2",
    "vitest": "3.2.4"
  }
}
